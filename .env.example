PROJECT_NAME=Emotion Tracker
VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=true

POSTGRES_USER=emotion_user
POSTGRES_PASSWORD=emotion_password
POSTGRES_DB=emotion_tracker
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://emotion_user:emotion_password@db:5432/emotion_tracker
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

SECRET_KEY=change_me_to_a_long_random_secret_key_of_at_least_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

FRONTEND_URL=http://localhost:3000
API_PORT=8000
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
